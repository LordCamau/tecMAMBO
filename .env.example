# tecMAMBO frontend
SITE_URL=https://tecmambo.com

# Content source. Keep local until the WordPress endpoint, credentials, migration, preview, and webhooks are verified.
CONTENT_SOURCE=local

# Headless WordPress and WPGraphQL
WORDPRESS_GRAPHQL_ENDPOINT=https://cms.tecmambo.com/graphql
# Server-only credential for preview and migration. Store a base64 username:application-password value for Basic auth.
WORDPRESS_API_TOKEN_OR_APP_PASSWORD=
WORDPRESS_PREVIEW_SECRET=

# Revalidation and WordPress webhook secrets
REVALIDATE_SECRET=
WP_WEBHOOK_SECRET=
SEARCH_REINDEX_SECRET=

# Search provider. Configure one provider during search cutover.
TYPESENSE_HOST=
TYPESENSE_API_KEY=
TYPESENSE_COLLECTION=tecmambo
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_API_KEY=
ALGOLIA_INDEX=tecmambo
